{
  "name": "packet-tracer-mcp",
  "mcpName": "io.github.jcorderop02/packet-tracer-mcp",
  "version": "0.1.0",
  "description": "Servidor MCP (Model Context Protocol) para Cisco Packet Tracer 9 — permite que un LLM como Claude o ChatGPT cree, edite y valide topologías de red en vivo (routers Cisco, switches, VLANs, OSPF, EIGRP, BGP, NAT, ACLs, VoIP, QoS, IPv6, wireless) a través del árbol IPC nativo del Script Engine de PT.",
  "author": "Juan Cordero Pascual <jcorderop@hotmail.es>",
  "license": "MIT",
  "homepage": "https://github.com/jcorderop02/packet-tracer-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcorderop02/packet-tracer-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/jcorderop02/packet-tracer-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "packet-tracer",
    "cisco-packet-tracer",
    "cisco",
    "networking",
    "network-simulation",
    "network-topology",
    "topology-generator",
    "ccna",
    "ccnp",
    "ios",
    "ospf",
    "eigrp",
    "bgp",
    "vlan",
    "nat",
    "acl",
    "voip",
    "qos",
    "ipv6",
    "wireless",
    "llm",
    "ai-agent",
    "claude",
    "chatgpt",
    "gemini",
    "anthropic",
    "openai",
    "ai-networking",
    "automation",
    "education",
    "bun",
    "typescript"
  ],
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "packet-tracer-mcp": "src/index.ts"
  },
  "files": [
    "src",
    "extension/dist/*.pts",
    "server.json",
    "README.md",
    "README.en.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/packet-tracer-mcp",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  }
}
